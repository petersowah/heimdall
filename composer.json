{
    "name": "petersowah/heimdall",
    "description": "Aing tool",
    "keywords": [
        "petersowah",
        "heimdall"
    ],
    "homepage": "https://github.com/petersowah/heimdall",
    "license": "MIT",
    "authors": [
        {
            "name": "petersowah",
            "email": "petersowah@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.0",
        "spatie/ray": "^1.28"
    },
    "autoload": {
        "psr-4": {
            "PeterSowah\\Heimdall\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PeterSowah\\Heimdall\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
            "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}

{
    "name": "petersowah/heimdall",
    "description": "Domain monitoring dashboard for Laravel — SSL, uptime, DNS, and WHOIS checks with multi-channel alerts.",
    "keywords": [
        "petersowah",
        "heimdall",
        "monitoring",
        "laravel"
    ],
    "homepage": "https://github.com/petersowah/heimdall",
    "license": "MIT",
    "authors": [
        {
            "name": "petersowah",
            "email": "petersowah@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/mail": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^4.7",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "PeterSowah\\Heimdall\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PeterSowah\\Heimdall\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PeterSowah\\Heimdall\\HeimdallServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
